<hc:Window x:Class="MotionStudio.App.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:vm="clr-namespace:MotionStudio.App.ViewModels"
           xmlns:views="clr-namespace:MotionStudio.App.Views"
           Title="{Binding WindowTitle}"
           Width="1920"
           Height="1080"
           MinWidth="1180"
           MinHeight="720"
           WindowStartupLocation="CenterScreen"
           Background="{StaticResource MotionBrush.WindowBackground}">
    <Grid Background="{StaticResource MotionBrush.WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{StaticResource MotionBrush.PanelAltBackground}"
                    BorderBrush="{StaticResource MotionBrush.Border}"
                    BorderThickness="0,0,0,1"
                    Padding="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <hc:Tag Content="{Binding CurrentRoleText}" Margin="0,0,8,0" />
                        <Button Content="角色登录" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding LoginCommand}" Margin="0,0,8,0" />
                        <Button Content="退出角色" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding LogoutCommand}" Margin="0,0,8,0" />
                        <hc:Tag Content="{Binding ProjectStateText}" Margin="0,0,8,0" />
                        <hc:Tag Content="{Binding MotionCardStateText}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding RuntimeState.IsRunning, Converter={StaticResource BoolToRunTextConverter}, StringFormat=流程:{0}}"
                                   Foreground="{StaticResource MotionBrush.TextPrimary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="新建项目" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding NewProjectCommand}" />
                        <Button Content="模板新建" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding NewProjectFromTemplateCommand}" />
                        <Button Content="打开项目" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding OpenProjectCommand}" />
                        <Button Content="保存项目" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding SaveProjectCommand}" />
                        <Separator Width="12" Background="Transparent" />
                        <Button Content="初始化运动卡" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding InitMotionCardCommand}" MinWidth="118" />
                        <Button Content="启动流程" Style="{StaticResource MotionRunButtonStyle}" Command="{Binding RunProcessCommand}" />
                        <Button Content="停止流程" Style="{StaticResource MotionStopButtonStyle}" Command="{Binding StopProcessCommand}" />
                        <Button Content="急停" Style="{StaticResource MotionEmergencyButtonStyle}" Command="{Binding EmergencyStopCommand}" />
                        <Button Content="单步执行" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding StepSelectedCommand}" />
                        <Button Content="清空流程" Style="{StaticResource MotionToolbarButtonStyle}" Command="{Binding ProcessBar.ClearCommand}" />
                        <Button Content="运行日志" Style="{StaticResource MotionToolbarButtonStyle}" Click="OpenLogWindow_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="118" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource MotionBrush.PanelBackground}"
                        BorderBrush="{StaticResource MotionBrush.Border}"
                        BorderThickness="0,0,1,0"
                        Padding="10,12">
                    <StackPanel>
                        <TextBlock Text="导航"
                                   Foreground="{StaticResource MotionBrush.TextPrimary}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10" />
                        <Button Content="流程编排"
                                Command="{Binding ShowProcessPageCommand}"
                                Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MotionToolbarButtonStyle}">
                                    <Setter Property="MinWidth" Value="0" />
                                    <Setter Property="Height" Value="44" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:WorkspacePage.Process}">
                                            <Setter Property="Background" Value="{StaticResource MotionBrush.Accent}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource MotionBrush.Accent}" />
                                            <Setter Property="Foreground" Value="{StaticResource MotionBrush.LightText}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="单轴调试"
                                Command="{Binding ShowSingleAxisDebugPageCommand}"
                                Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MotionToolbarButtonStyle}">
                                    <Setter Property="MinWidth" Value="0" />
                                    <Setter Property="Height" Value="44" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:WorkspacePage.SingleAxisDebug}">
                                            <Setter Property="Background" Value="{StaticResource MotionBrush.Accent}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource MotionBrush.Accent}" />
                                            <Setter Property="Foreground" Value="{StaticResource MotionBrush.LightText}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1">
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="{x:Type Grid}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:WorkspacePage.Process}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="340" />
                        </Grid.ColumnDefinitions>

                        <views:MotionModuleBar Grid.Column="0" DataContext="{Binding ModuleBar}" />
                        <views:MotionProcessBar Grid.Column="1" DataContext="{Binding ProcessBar}" />
                        <views:MotionPropertyPanel Grid.Column="2" DataContext="{Binding PropertyPanel}" />
                    </Grid>

                    <views:SingleAxisDebugView DataContext="{Binding SingleAxisDebug}">
                        <views:SingleAxisDebugView.Style>
                            <Style TargetType="{x:Type views:SingleAxisDebugView}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="{x:Static vm:WorkspacePage.SingleAxisDebug}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:SingleAxisDebugView.Style>
                    </views:SingleAxisDebugView>
                </Grid>
            </Grid>

            <views:MotionStatusPanel Grid.Row="2" DataContext="{Binding}" />
        </Grid>
        <!--左下角提示区域，避免遮挡右侧轴参数和工具按钮-->
        <StackPanel x:Name="GrowlHost"
                    Width="360"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="16,0,0,16"
                    Panel.ZIndex="20" />
    </Grid>
</hc:Window>

