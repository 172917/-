<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="MotionPropertyLabelStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource MotionBrush.TextSecondary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <Style x:Key="MotionPropertyValueStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource MotionBrush.TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,2,0,8" />
    </Style>
</ResourceDictionary>
