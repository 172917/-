<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="MotionPanelBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource MotionBrush.PanelBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBrush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Margin" Value="6" />
    </Style>

    <Style x:Key="MotionInnerCardBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource MotionBrush.CardBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBrush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <Style x:Key="MotionSectionTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource MotionBrush.TextPrimary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MotionMutedTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource MotionBrush.TextSecondary}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
</ResourceDictionary>
