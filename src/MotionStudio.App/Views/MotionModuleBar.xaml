<UserControl x:Class="MotionStudio.App.Views.MotionModuleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Border Style="{StaticResource MotionPanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <TextBlock Text="功能模块" Style="{StaticResource MotionSectionTitleStyle}" />
                <TextBlock DockPanel.Dock="Right"
                           Text="拖入流程"
                           Style="{StaticResource MotionMutedTextStyle}"
                           HorizontalAlignment="Right" />
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ModuleGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander IsExpanded="True" Margin="0,0,0,8" Foreground="{StaticResource MotionBrush.TextPrimary}">
                                <Expander.Header>
                                    <DockPanel MinHeight="30" LastChildFill="False">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   Foreground="{StaticResource MotionBrush.TextPrimary}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Count}"
                                                   Foreground="{StaticResource MotionBrush.Accent}"
                                                   FontWeight="SemiBold"
                                                   Margin="18,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </Expander.Header>
                                <!--ListBox：显示当前分类下的模块-->
                                <ListBox ItemsSource="{Binding Modules}"
                                         Style="{StaticResource MotionModuleListBoxStyle}"
                                         ItemContainerStyle="{StaticResource MotionModuleListBoxItemStyle}"
                                         PreviewMouseMove="ModuleList_PreviewMouseMove">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                          
                                                <Border Style="{StaticResource MotionInnerCardBorderStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="64" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Icon}"
                                                                   Style="{StaticResource MotionModuleIconTextStyle}" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                                                            <TextBlock Text="{Binding PluginName}"
                                                                       Foreground="{StaticResource MotionBrush.TextPrimary}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="14"
                                                                       LineHeight="20" />
                                                            <TextBlock Text="{Binding Description}"
                                                                       Style="{StaticResource MotionMutedTextStyle}"
                                                                       Margin="0,3,0,0"
                                                                       LineHeight="18"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
