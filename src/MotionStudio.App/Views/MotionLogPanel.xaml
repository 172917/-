<UserControl x:Class="MotionStudio.App.Views.MotionLogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource MotionPanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="打印日志"
                        Style="{StaticResource MotionToolbarButtonStyle}"
                        Command="{Binding ExportLogsCommand}"
                        MinWidth="88"
                        Margin="8,0,0,8" />
                <TextBlock Text="运行日志" Style="{StaticResource MotionSectionTitleStyle}" />
            </DockPanel>

            <DataGrid Grid.Row="1"
                      Style="{StaticResource MotionLogDataGridStyle}"
                      ItemsSource="{Binding Logs}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat=HH:mm:ss.fff}" Width="130" />
                    <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="80" />
                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="130" />
                    <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="*" />
                    <DataGridTextColumn Header="API调用" Binding="{Binding ApiCall}" Width="320" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
