<UserControl x:Class="MotionStudio.App.Views.MotionLogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource MotionPanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="运行日志" Style="{StaticResource MotionSectionTitleStyle}" />

            <DataGrid Grid.Row="1"
                      Style="{StaticResource MotionLogDataGridStyle}"
                      ItemsSource="{Binding Logs}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat=HH:mm:ss.fff}" Width="130" />
                    <DataGridTextColumn Header="等级" Binding="{Binding Level}" Width="80" />
                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="130" />
                    <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
