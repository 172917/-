<UserControl x:Class="MotionStudio.App.Views.MotionPropertyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Border Style="{StaticResource MotionPanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="参数区" Style="{StaticResource MotionSectionTitleStyle}" />

            <Border Grid.Row="1" Style="{StaticResource MotionInnerCardBorderStyle}">
           
                <StackPanel>
                    <TextBlock Text="当前模块" Style="{StaticResource MotionPropertyLabelStyle}" />
                    <TextBlock Text="{Binding SelectedParam.ModuleName, TargetNullValue=未选择模块}"
                               Style="{StaticResource MotionPropertyValueStyle}"
                                Foreground="{StaticResource MotionBrush.Accent}"
                               HorizontalAlignment="Center"
                               />
                    <TextBlock Text="插件" Style="{StaticResource MotionPropertyLabelStyle}" />
                    <TextBlock Text="{Binding SelectedParam.PluginName, TargetNullValue=-}"
                               Style="{StaticResource MotionPropertyValueStyle}"
                                Foreground="{StaticResource MotionBrush.Accent}"
                               HorizontalAlignment="Center"
                               />
                    <TextBlock Text="运动卡" Style="{StaticResource MotionPropertyLabelStyle}" />
                    <ComboBox ItemsSource="{Binding MotionCardNames}"
                              SelectedItem="{Binding SelectedParam.MotionCardName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding CanEdit}"
                              MinHeight="30"
                              Margin="0,0,0,8" />
                    <TextBlock Text="备注" Style="{StaticResource MotionPropertyLabelStyle}" />
                    <TextBox Text="{Binding SelectedParam.Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEdit}"
                             MinHeight="54"
                             MaxLines="3"
                             TextWrapping="Wrap"
                             Padding="8,5"
                             Margin="0,0,0,8"
                             BorderBrush="{StaticResource MotionBrush.Border}"
                             Foreground="{StaticResource MotionBrush.TextPrimary}" />
                    
                </StackPanel>
            </Border>

            <hc:PropertyGrid Grid.Row="2"
                             Margin="0,8,0,0"
                             IsEnabled="{Binding CanEdit}"
                             SelectedObject="{Binding SelectedModule}" />
        </Grid>
    </Border>
</UserControl>
