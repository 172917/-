<UserControl x:Class="MotionStudio.App.Views.SingleAxisDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:MotionStudio.App.ViewModels"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <Style x:Key="AxisCompactButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MotionToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="AxisCompactRunButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MotionRunButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="AxisOperationButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MotionToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="AxisOperationRunButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MotionRunButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="AxisOperationStopButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MotionStopButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="AxisOperationEmergencyButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MotionEmergencyButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="AxisListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource MotionBrush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{StaticResource MotionBrush.CardBackground}"
                                BorderBrush="{StaticResource MotionBrush.Border}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                MinHeight="62">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource MotionBrush.CardSelected}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource MotionBrush.Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource MotionBrush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AxisParameterTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="{StaticResource MotionBrush.Border}" />
            <Setter Property="Foreground" Value="{StaticResource MotionBrush.TextPrimary}" />
        </Style>

        <Style x:Key="AxisRowLabelStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MotionPropertyLabelStyle}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="AxisStateBoxStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#EFF2F5" />
            <Setter Property="BorderBrush" Value="#D0D7DE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#3CB371" />
                    <Setter Property="BorderBrush" Value="#2E8B57" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AxisStateTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#2F3A46" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource MotionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="轴列表" Style="{StaticResource MotionSectionTitleStyle}" />
                    <TextBlock DockPanel.Dock="Right" Text="{Binding Axes.Count, StringFormat=轴 {0}}" Style="{StaticResource MotionMutedTextStyle}" VerticalAlignment="Center" />
                </DockPanel>

                <UniformGrid Grid.Row="1" Columns="4" Margin="-3,0,-3,10">
                    <Button Content="新增" Style="{StaticResource AxisCompactButtonStyle}" Command="{Binding AddAxisCommand}" />
                    <Button Content="复制" Style="{StaticResource AxisCompactButtonStyle}" Command="{Binding CopyAxisCommand}" />
                    <Button Content="删除" Style="{StaticResource AxisCompactButtonStyle}" Command="{Binding DeleteAxisCommand}" />
                    <Button Content="保存" Style="{StaticResource AxisCompactRunButtonStyle}" Command="{Binding SaveAxisConfigCommand}" />
                </UniformGrid>

                <ListBox Grid.Row="2" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxis, Mode=TwoWay}" Style="{StaticResource MotionProcessListBoxStyle}" ItemContainerStyle="{StaticResource AxisListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding AxisNo}" Foreground="{StaticResource MotionBrush.Accent}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AxisName}" Foreground="{StaticResource MotionBrush.TextPrimary}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Style="{StaticResource MotionMutedTextStyle}">
                                        <Run Text="运动卡 " />
                                        <Run Text="{Binding MotionCardName}" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource MotionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="{Binding SelectedAxisTitle}" Foreground="{StaticResource MotionBrush.TextPrimary}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <hc:Tag DockPanel.Dock="Right" Content="{Binding ConnectionHint}" VerticalAlignment="Center" />
                </DockPanel>

                <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisServoOn}"><TextBlock Text="伺服" Style="{StaticResource AxisStateTextStyle}" /></Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisHomed}"><TextBlock Text="回零" Style="{StaticResource AxisStateTextStyle}" /></Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisMoving}"><TextBlock Text="运动中" Style="{StaticResource AxisStateTextStyle}" /></Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisAlarm}"><TextBlock Text="报警" Style="{StaticResource AxisStateTextStyle}" /></Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisPositiveLimit}"><TextBlock Text="正限位" Style="{StaticResource AxisStateTextStyle}" /></Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisNegativeLimit}"><TextBlock Text="负限位" Style="{StaticResource AxisStateTextStyle}" /></Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisArrived}"><TextBlock Text="到位" Style="{StaticResource AxisStateTextStyle}" /></Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisEmergencyStop}"><TextBlock Text="急停" Style="{StaticResource AxisStateTextStyle}" /></Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisStopped}"><TextBlock Text="停止" Style="{StaticResource AxisStateTextStyle}" /></Border>
                </WrapPanel>

                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="120" /><ColumnDefinition Width="90" /><ColumnDefinition Width="16" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="120" /><ColumnDefinition Width="90" /></Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="规划位置" VerticalAlignment="Center" /><TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PlannedPosition, StringFormat={}{0:F6}}" VerticalAlignment="Center" /><TextBlock Grid.Row="0" Grid.Column="2" Text="脉冲" VerticalAlignment="Center" /><TextBlock Grid.Row="0" Grid.Column="4" Text="实际位置" VerticalAlignment="Center" /><TextBlock Grid.Row="0" Grid.Column="5" Text="{Binding ActualPosition, StringFormat={}{0:F6}}" VerticalAlignment="Center" /><TextBlock Grid.Row="0" Grid.Column="6" Text="脉冲" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="规划速度" VerticalAlignment="Center" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PlannedVelocity, StringFormat={}{0:F6}}" VerticalAlignment="Center" /><TextBlock Grid.Row="1" Grid.Column="2" Text="脉冲/毫秒" VerticalAlignment="Center" /><TextBlock Grid.Row="1" Grid.Column="4" Text="实际速度" VerticalAlignment="Center" /><TextBlock Grid.Row="1" Grid.Column="5" Text="{Binding ActualVelocity, StringFormat={}{0:F6}}" VerticalAlignment="Center" /><TextBlock Grid.Row="1" Grid.Column="6" Text="脉冲/毫秒" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="规划加速度" VerticalAlignment="Center" /><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PlannedAcceleration, StringFormat={}{0:F6}}" VerticalAlignment="Center" /><TextBlock Grid.Row="2" Grid.Column="2" Text="脉冲/毫秒²" VerticalAlignment="Center" /><TextBlock Grid.Row="2" Grid.Column="4" Text="实际加速度" VerticalAlignment="Center" /><TextBlock Grid.Row="2" Grid.Column="5" Text="{Binding ActualAcceleration, StringFormat={}{0:F6}}" VerticalAlignment="Center" /><TextBlock Grid.Row="2" Grid.Column="6" Text="脉冲/毫秒²" VerticalAlignment="Center" />
                </Grid>

                <Border Grid.Row="3" Style="{StaticResource MotionInnerCardBorderStyle}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.3*" /><ColumnDefinition Width="1.3*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,16,0"><TextBlock Text="状态消息" Style="{StaticResource MotionMutedTextStyle}" /><TextBlock Text="{Binding CurrentState.Message, TargetNullValue=-}" Foreground="{StaticResource MotionBrush.TextPrimary}" TextWrapping="Wrap" /></StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,16,0"><TextBlock Text="操作消息" Style="{StaticResource MotionMutedTextStyle}" /><TextBlock Text="{Binding OperationMessage}" Foreground="{StaticResource MotionBrush.TextPrimary}" TextWrapping="Wrap" /></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="调试参数" Style="{StaticResource MotionMutedTextStyle}" /><TextBlock Foreground="{StaticResource MotionBrush.TextPrimary}"><Run Text="目标 " /><Run Text="{Binding SelectedAxis.TargetPosition, Mode=OneWay}" /><Run Text=" / 相对 " /><Run Text="{Binding SelectedAxis.RelativeDistance, Mode=OneWay}" /></TextBlock></StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Background="{StaticResource MotionBrush.CardBackground}" BorderBrush="{StaticResource MotionBrush.Border}" BorderThickness="1" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="操作模式" Foreground="{StaticResource MotionBrush.TextPrimary}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />
                        <UniformGrid Columns="4" Margin="-4,0,-4,4">
                            <Button Content="回零" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding SelectOperationCommand}" CommandParameter="{x:Static vm:AxisDebugOperationMode.Home}" />
                            <Button Content="绝对运动" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding SelectOperationCommand}" CommandParameter="{x:Static vm:AxisDebugOperationMode.AbsoluteMove}" />
                            <Button Content="相对运动" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding SelectOperationCommand}" CommandParameter="{x:Static vm:AxisDebugOperationMode.RelativeMove}" />
                            <Button Content="Jog运动" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding SelectOperationCommand}" CommandParameter="{x:Static vm:AxisDebugOperationMode.Jog}" />
                        </UniformGrid>
                        <UniformGrid Columns="5" Margin="-4,4,-4,0">
                            <Button Content="上使能" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding ServoOnCommand}" />
                            <Button Content="下使能" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding ServoOffCommand}" />
                            <Button Content="报警复位" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding ClearAlarmCommand}" />
                            <Button Content="位置清零" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding ZeroPositionCommand}" />
                            <Button Content="全部复位" Style="{StaticResource AxisOperationButtonStyle}" Command="{Binding ClearAllAlarmCommand}" />
                        </UniformGrid>
                        <UniformGrid Columns="2" Margin="-4,4,-4,0">
                            <Button Content="停止" Style="{StaticResource AxisOperationStopButtonStyle}" Command="{Binding StopAxisCommand}" />
                            <Button Content="急停" Style="{StaticResource AxisOperationEmergencyButtonStyle}" Command="{Binding EmergencyStopAxisCommand}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource MotionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <TextBlock Text="轴参数" Style="{StaticResource MotionSectionTitleStyle}" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel IsEnabled="{Binding HasSelectedAxis}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="轴名称" Style="{StaticResource AxisRowLabelStyle}" />
                            <TextBox Grid.Column="1" Text="{Binding SelectedAxis.AxisName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="轴号" Style="{StaticResource AxisRowLabelStyle}" />
                            <TextBox Grid.Column="1" Text="{Binding SelectedAxis.AxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="运动卡" Style="{StaticResource AxisRowLabelStyle}" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding MotionCardNames}" SelectedItem="{Binding SelectedAxis.MotionCardName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="速度比例" Style="{StaticResource AxisRowLabelStyle}" />
                            <TextBox Grid.Column="1" Text="{Binding SelectedAxis.VelocityRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" />
                        </Grid>

                        <Separator Margin="0,6,0,8" />
                        <TextBlock Text="当前运动参数" Style="{StaticResource MotionPropertyLabelStyle}" Margin="0,0,0,6" />

                        <StackPanel Visibility="{Binding IsHomeMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="回零速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.HomeVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="回零加速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.HomeAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="回零减速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.HomeDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="超时(秒)" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.HomeTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <UniformGrid Columns="2" Margin="-4,0,-4,10"><Button Content="开始回零" Style="{StaticResource AxisOperationRunButtonStyle}" Command="{Binding HomeCommand}" /><Button Content="停止" Style="{StaticResource AxisOperationStopButtonStyle}" Command="{Binding StopAxisCommand}" /></UniformGrid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsAbsoluteMoveMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="目标位置" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.TargetPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.AbsVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="加速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.AbsAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="减速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.AbsDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <UniformGrid Columns="2" Margin="-4,0,-4,10"><Button Content="启动" Style="{StaticResource AxisOperationRunButtonStyle}" Command="{Binding AbsMoveCommand}" /><Button Content="停止" Style="{StaticResource AxisOperationStopButtonStyle}" Command="{Binding StopAxisCommand}" /></UniformGrid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsRelativeMoveMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="相对位移" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.RelativeDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.RelVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="加速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.RelAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="减速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding SelectedAxis.RelDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <UniformGrid Columns="2" Margin="-4,0,-4,10"><Button Content="启动" Style="{StaticResource AxisOperationRunButtonStyle}" Command="{Binding RelMoveCommand}" /><Button Content="停止" Style="{StaticResource AxisOperationStopButtonStyle}" Command="{Binding StopAxisCommand}" /></UniformGrid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsJogMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="Jog速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding JogVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="Jog加速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding JogAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="Jog减速度" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding JogDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="平滑系数" Style="{StaticResource AxisRowLabelStyle}" /><TextBox Grid.Column="1" Text="{Binding JogSmoothTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AxisParameterTextBoxStyle}" /></Grid>
                            <UniformGrid Columns="2" Margin="-4,0,-4,10">
                                <Button x:Name="JogNegativeButton" Content="Jog-" Style="{StaticResource AxisOperationButtonStyle}" PreviewMouseLeftButtonDown="JogNegativeButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" MouseLeave="JogButton_MouseLeave" LostMouseCapture="JogButton_LostMouseCapture" />
                                <Button x:Name="JogPositiveButton" Content="Jog+" Style="{StaticResource AxisOperationButtonStyle}" PreviewMouseLeftButtonDown="JogPositiveButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" MouseLeave="JogButton_MouseLeave" LostMouseCapture="JogButton_LostMouseCapture" />
                            </UniformGrid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
