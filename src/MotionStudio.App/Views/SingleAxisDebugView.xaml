<UserControl
    x:Class="MotionStudio.App.Views.SingleAxisDebugView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:motion="clr-namespace:MotionStudio.Motion.Abstractions;assembly=MotionStudio.Motion" xmlns:vm="clr-namespace:MotionStudio.App.ViewModels"
    Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <Style x:Key="AxisCompactButtonStyle" BasedOn="{StaticResource MotionToolbarButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="AxisCompactRunButtonStyle" BasedOn="{StaticResource MotionRunButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="AxisOperationButtonStyle" BasedOn="{StaticResource MotionToolbarButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="AxisOperationRunButtonStyle" BasedOn="{StaticResource MotionRunButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="AxisOperationStopButtonStyle" BasedOn="{StaticResource MotionStopButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="AxisOperationEmergencyButtonStyle" BasedOn="{StaticResource MotionEmergencyButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="AxisListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource MotionBrush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border
                            x:Name="ItemBorder" MinHeight="62"
                            Padding="10"
                            Background="{StaticResource MotionBrush.CardBackground}"
                            BorderBrush="{StaticResource MotionBrush.Border}"
                            BorderThickness="1" CornerRadius="6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource MotionBrush.CardSelected}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource MotionBrush.Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource MotionBrush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AxisParameterTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="{StaticResource MotionBrush.Border}" />
            <Setter Property="Foreground" Value="{StaticResource MotionBrush.TextPrimary}" />
        </Style>

        <Style x:Key="AxisRowLabelStyle" BasedOn="{StaticResource MotionPropertyLabelStyle}" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="AxisStateBoxStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#EFF2F5" />
            <Setter Property="BorderBrush" Value="#D0D7DE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#3CB371" />
                    <Setter Property="BorderBrush" Value="#2E8B57" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AxisStateTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#2F3A46" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource MotionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource MotionSectionTitleStyle}" Text="轴列表" />
                    <TextBlock VerticalAlignment="Center" DockPanel.Dock="Right" Style="{StaticResource MotionMutedTextStyle}" Text="{Binding Axes.Count, StringFormat=轴 {0}}" />
                </DockPanel>

                <UniformGrid Grid.Row="1" Margin="-3,0,-3,10" Columns="4">
                    <Button Command="{Binding AddAxisCommand}" Content="新增" Style="{StaticResource AxisCompactButtonStyle}" />
                    <Button Command="{Binding CopyAxisCommand}" Content="复制" Style="{StaticResource AxisCompactButtonStyle}" />
                    <Button Command="{Binding DeleteAxisCommand}" Content="删除" Style="{StaticResource AxisCompactButtonStyle}" />
                    <Button Command="{Binding SaveAxisConfigCommand}" Content="保存" Style="{StaticResource AxisCompactRunButtonStyle}" />
                </UniformGrid>

                <ListBox Grid.Row="2" ItemContainerStyle="{StaticResource AxisListBoxItemStyle}" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxis, Mode=TwoWay}" Style="{StaticResource MotionProcessListBoxStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource MotionBrush.Accent}" Text="{Binding AxisNo}" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MotionBrush.TextPrimary}" Text="{Binding AxisName}" />
                                    <TextBlock Style="{StaticResource MotionMutedTextStyle}">
                                        <Run Text="运动卡 " />
                                        <Run Text="{Binding MotionCardName}" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource MotionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource MotionBrush.TextPrimary}" Text="{Binding SelectedAxisTitle}" />
                    <hc:Tag VerticalAlignment="Center" Content="{Binding ConnectionHint}" DockPanel.Dock="Right" />
                </DockPanel>

                <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisServoOn}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="伺服" />
                    </Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisHomed}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="回零" />
                    </Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisMoving}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="运动中" />
                    </Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisAlarm}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="报警" />
                    </Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisPositiveLimit}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="正限位" />
                    </Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisNegativeLimit}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="负限位" />
                    </Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisArrived}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="到位" />
                    </Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisEmergencyStop}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="急停" />
                    </Border>
                    <Border Style="{StaticResource AxisStateBoxStyle}" Tag="{Binding SelectedAxisStopped}">
                        <TextBlock Style="{StaticResource AxisStateTextStyle}" Text="停止" />
                    </Border>
                </WrapPanel>

                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="规划位置" />
                    <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="{Binding PlannedPosition, StringFormat={}{0:F6}}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="脉冲" />
                    <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="实际位置" />
                    <TextBlock Grid.Row="0" Grid.Column="5" VerticalAlignment="Center" Text="{Binding ActualPosition, StringFormat={}{0:F6}}" />
                    <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center" Text="脉冲" />
                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="规划速度" />
                    <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="{Binding PlannedVelocity, StringFormat={}{0:F6}}" />
                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="脉冲/毫秒" />
                    <TextBlock Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" Text="实际速度" />
                    <TextBlock Grid.Row="1" Grid.Column="5" VerticalAlignment="Center" Text="{Binding ActualVelocity, StringFormat={}{0:F6}}" />
                    <TextBlock Grid.Row="1" Grid.Column="6" VerticalAlignment="Center" Text="脉冲/毫秒" />
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="规划加速度" />
                    <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="{Binding PlannedAcceleration, StringFormat={}{0:F6}}" />
                    <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="脉冲/毫秒²" />
                    <TextBlock Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Text="实际加速度" />
                    <TextBlock Grid.Row="2" Grid.Column="5" VerticalAlignment="Center" Text="{Binding ActualAcceleration, StringFormat={}{0:F6}}" />
                    <TextBlock Grid.Row="2" Grid.Column="6" VerticalAlignment="Center" Text="脉冲/毫秒²" />
                </Grid>

                <Border Grid.Row="3" Margin="0,0,0,8" Style="{StaticResource MotionInnerCardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource MotionMutedTextStyle}" Text="状态消息" />
                            <TextBlock Foreground="{StaticResource MotionBrush.TextPrimary}" Text="{Binding CurrentState.Message, TargetNullValue=-}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource MotionMutedTextStyle}" Text="操作消息" />
                            <TextBlock Foreground="{StaticResource MotionBrush.TextPrimary}" Text="{Binding OperationMessage}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource MotionMutedTextStyle}" Text="调试参数" />
                            <TextBlock Foreground="{StaticResource MotionBrush.TextPrimary}"><Run Text="目标 " /><Run Text="{Binding SelectedAxis.TargetPosition, Mode=OneWay}" /><Run Text=" / 相对 " /><Run Text="{Binding SelectedAxis.RelativeDistance, Mode=OneWay}" /></TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="4" Padding="12"
                    Background="{StaticResource MotionBrush.CardBackground}"
                    BorderBrush="{StaticResource MotionBrush.Border}"
                    BorderThickness="1" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MotionBrush.TextPrimary}" Text="操作模式" />
                        <UniformGrid Margin="-4,0,-4,4" Columns="4">
                            <Button Command="{Binding SelectOperationCommand}" CommandParameter="{x:Static vm:AxisDebugOperationMode.Home}" Content="回零" Style="{StaticResource AxisOperationButtonStyle}" />
                            <Button Command="{Binding SelectOperationCommand}" CommandParameter="{x:Static vm:AxisDebugOperationMode.AbsoluteMove}" Content="绝对运动" Style="{StaticResource AxisOperationButtonStyle}" />
                            <Button Command="{Binding SelectOperationCommand}" CommandParameter="{x:Static vm:AxisDebugOperationMode.RelativeMove}" Content="相对运动" Style="{StaticResource AxisOperationButtonStyle}" />
                            <Button Command="{Binding SelectOperationCommand}" CommandParameter="{x:Static vm:AxisDebugOperationMode.Jog}" Content="Jog运动" Style="{StaticResource AxisOperationButtonStyle}" />
                        </UniformGrid>
                        <UniformGrid Margin="-4,4,-4,0" Columns="5">
                            <Button Command="{Binding ServoOnCommand}" Content="上使能" Style="{StaticResource AxisOperationButtonStyle}" />
                            <Button Command="{Binding ServoOffCommand}" Content="下使能" Style="{StaticResource AxisOperationButtonStyle}" />
                            <Button Command="{Binding ClearAlarmCommand}" Content="报警复位" Style="{StaticResource AxisOperationButtonStyle}" />
                            <Button Command="{Binding ZeroPositionCommand}" Content="位置清零" Style="{StaticResource AxisOperationButtonStyle}" />
                            <Button Command="{Binding ClearAllAlarmCommand}" Content="全部复位" Style="{StaticResource AxisOperationButtonStyle}" />
                        </UniformGrid>
                        <UniformGrid Margin="-4,4,-4,0" Columns="2">
                            <Button Command="{Binding StopAxisCommand}" Content="停止" Style="{StaticResource AxisOperationStopButtonStyle}" />
                            <Button Command="{Binding EmergencyStopAxisCommand}" Content="急停" Style="{StaticResource AxisOperationEmergencyButtonStyle}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource MotionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource MotionSectionTitleStyle}" Text="轴参数" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel IsEnabled="{Binding HasSelectedAxis}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="轴名称" />
                            <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.AxisName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="轴号" />
                            <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.AxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="运动卡" />
                            <ComboBox Grid.Column="1" Height="30" ItemsSource="{Binding MotionCardNames}" SelectedItem="{Binding SelectedAxis.MotionCardName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="速度比例" />
                            <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.VelocityRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Separator Margin="0,6,0,8" />
                        <TextBlock Margin="0,0,0,6" Style="{StaticResource MotionPropertyLabelStyle}" Text="当前运动参数" />

                        <StackPanel Visibility="{Binding IsHomeMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="编码器方向" />
                                <UniformGrid Grid.Column="1" Columns="2">
                                    <RadioButton VerticalAlignment="Center" Content="正向" GroupName="HomeEncoderDirection" IsChecked="{Binding SelectedAxis.HomeEncoderDirection, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeEncoderDirection.Positive}}" />
                                    <RadioButton VerticalAlignment="Center" Content="负向" GroupName="HomeEncoderDirection" IsChecked="{Binding SelectedAxis.HomeEncoderDirection, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeEncoderDirection.Negative}}" />
                                </UniformGrid>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="正限位" />
                                <UniformGrid Grid.Column="1" Columns="2">
                                    <RadioButton VerticalAlignment="Center" Content="高电平" GroupName="HomePositiveLimit" IsChecked="{Binding SelectedAxis.HomePositiveLimitTriggerLevel, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeSignalLevel.High}}" />
                                    <RadioButton VerticalAlignment="Center" Content="低电平" GroupName="HomePositiveLimit" IsChecked="{Binding SelectedAxis.HomePositiveLimitTriggerLevel, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeSignalLevel.Low}}" />
                                </UniformGrid>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="负限位" />
                                <UniformGrid Grid.Column="1" Columns="2">
                                    <RadioButton VerticalAlignment="Center" Content="高电平" GroupName="HomeNegativeLimit" IsChecked="{Binding SelectedAxis.HomeNegativeLimitTriggerLevel, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeSignalLevel.High}}" />
                                    <RadioButton VerticalAlignment="Center" Content="低电平" GroupName="HomeNegativeLimit" IsChecked="{Binding SelectedAxis.HomeNegativeLimitTriggerLevel, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeSignalLevel.Low}}" />
                                </UniformGrid>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="回零方式" />
                                <ComboBox
                                    Grid.Column="1" Height="30"
                                    DisplayMemberPath="DisplayName"
                                    ItemsSource="{Binding HomeModeOptions}"
                                    SelectedValue="{Binding SelectedAxis.HomeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Mode" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="搜索方向" />
                                <UniformGrid Grid.Column="1" Columns="2">
                                    <RadioButton VerticalAlignment="Center" Content="正向" GroupName="HomeSearchDirection" IsChecked="{Binding SelectedAxis.HomeSearchDirection, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeSearchDirection.Positive}}" />
                                    <RadioButton VerticalAlignment="Center" Content="负向" GroupName="HomeSearchDirection" IsChecked="{Binding SelectedAxis.HomeSearchDirection, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeSearchDirection.Negative}}" />
                                </UniformGrid>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="触发沿" />
                                <UniformGrid Grid.Column="1" Columns="2">
                                    <RadioButton VerticalAlignment="Center" Content="下降沿" GroupName="HomeCaptureEdge" IsChecked="{Binding SelectedAxis.HomeCaptureEdge, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeCaptureEdge.Falling}}" />
                                    <RadioButton VerticalAlignment="Center" Content="上升沿" GroupName="HomeCaptureEdge" IsChecked="{Binding SelectedAxis.HomeCaptureEdge, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static motion:HomeCaptureEdge.Rising}}" />
                                </UniformGrid>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="寻原点高速" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.HomeVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="寻原点低速" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.HomeLowVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="回零加速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.HomeAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="回零减速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.HomeDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="搜索距离" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.HomeSearchDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="escapeStep" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.HomeEscapeStep, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="超时(秒)" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.HomeTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <UniformGrid Margin="-4,0,-4,10" Columns="2">
                                <Button Command="{Binding HomeCommand}" Content="开始回零" Style="{StaticResource AxisOperationRunButtonStyle}" />
                                <Button Command="{Binding StopAxisCommand}" Content="停止" Style="{StaticResource AxisOperationStopButtonStyle}" />
                            </UniformGrid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsAbsoluteMoveMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="目标位置" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.TargetPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.AbsVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="加速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.AbsAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="减速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.AbsDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <UniformGrid Margin="-4,0,-4,10" Columns="2">
                                <Button Command="{Binding AbsMoveCommand}" Content="启动" Style="{StaticResource AxisOperationRunButtonStyle}" />
                                <Button Command="{Binding StopAxisCommand}" Content="停止" Style="{StaticResource AxisOperationStopButtonStyle}" />
                            </UniformGrid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsRelativeMoveMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="相对位移" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.RelativeDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.RelVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="加速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.RelAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="减速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding SelectedAxis.RelDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <UniformGrid Margin="-4,0,-4,10" Columns="2">
                                <Button Command="{Binding RelMoveCommand}" Content="启动" Style="{StaticResource AxisOperationRunButtonStyle}" />
                                <Button Command="{Binding StopAxisCommand}" Content="停止" Style="{StaticResource AxisOperationStopButtonStyle}" />
                            </UniformGrid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsJogMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="Jog速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding JogVelocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="Jog加速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding JogAcceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="Jog减速度" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding JogDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource AxisRowLabelStyle}" Text="平滑系数" />
                                <TextBox Grid.Column="1" Style="{StaticResource AxisParameterTextBoxStyle}" Text="{Binding JogSmoothTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <UniformGrid Margin="-4,0,-4,10" Columns="2">
                                <Button
                                    x:Name="JogNegativeButton" Content="Jog-"
                                    LostMouseCapture="JogButton_LostMouseCapture" MouseLeave="JogButton_MouseLeave"
                                    PreviewMouseLeftButtonDown="JogNegativeButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp"
                                    Style="{StaticResource AxisOperationButtonStyle}" />
                                <Button
                                    x:Name="JogPositiveButton" Content="Jog+"
                                    LostMouseCapture="JogButton_LostMouseCapture" MouseLeave="JogButton_MouseLeave"
                                    PreviewMouseLeftButtonDown="JogPositiveButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp"
                                    Style="{StaticResource AxisOperationButtonStyle}" />
                            </UniformGrid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
