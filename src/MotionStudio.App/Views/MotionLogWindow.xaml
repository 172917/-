<hc:Window x:Class="MotionStudio.App.Views.MotionLogWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:views="clr-namespace:MotionStudio.App.Views"
           Title="运行日志"
           Width="960"
           Height="520"
           MinWidth="720"
           MinHeight="360"
           WindowStartupLocation="CenterOwner"
           Background="{StaticResource MotionBrush.WindowBackground}">
    <Grid Background="{StaticResource MotionBrush.WindowBackground}">
        <views:MotionLogPanel DataContext="{Binding}" />
    </Grid>
</hc:Window>
